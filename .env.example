# ===========================================================================
# Vet-eye CareBot (PoC) — environment configuration
# Copy this file to ".env" and fill in the values from your Azure resources.
# In Azure App Service, set these as Application Settings instead of a file.
# ===========================================================================

# --- Microsoft Foundry / Azure OpenAI ---------------------------------------
# Endpoint of your Foundry / Azure OpenAI resource.
#   Azure OpenAI style : https://<resource-name>.openai.azure.com/
#   Foundry style      : https://<resource-name>.services.ai.azure.com/
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Deployment names you created in Foundry (NOT the base model names if you
# named the deployments differently).
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
# text-embedding-3-large native size is 3072. Keep this in sync with the index.
EMBEDDING_DIMENSIONS=3072

# --- Azure AI Search --------------------------------------------------------
AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX=carebot-manuals

# --- Retrieval / generation tuning (optional) -------------------------------
RAG_TOP_K=8
# Also pull page±1 of each hit (procedures span page breaks): true | false
RAG_NEIGHBOR_EXPANSION=true
# gpt-5 family reasoning effort: minimal | low | medium | high
RAG_REASONING_EFFORT=low
# Budget must leave room for answer tokens after reasoning, or content comes
# back empty; the pipeline retries at 2x, but start high enough for procedures.
RAG_MAX_COMPLETION_TOKENS=2000
